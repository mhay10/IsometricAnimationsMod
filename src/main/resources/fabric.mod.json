{
  "schemaVersion": 1,
  "id": "isometric-animations",
  "version": "${version}",
  "name": "Isometric Animations",
  "description": "Creates high-quality animations rendered in an isometric style",
  "authors": [
    "mhay10"
  ],
  "contact": {
    "homepage": "https://github.com/mhay10/IsometricAnimationsMod",
    "sources": "https://github.com/mhay10/IsometricAnimationsMod"
  },
  "license": "CC0-1.0",
  "icon": "assets/isometric-animations/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.isoanimations.IsometricAnimations"
    ],
    "client": [
      "com.isoanimations.IsometricAnimationsClient"
    ]
  },
  "mixins": [
    "isometric-animations.mixins.json",
    {
      "config": "isometric-animations.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "sodium": ">=0.8.7",
    "modmenu": "*"
  },
  "breaks": {
    "sodium": "<0.8.7"
  }
}